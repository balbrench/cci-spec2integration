{
  "definition": {
    "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
    "actions": {
      "Agent_Loop": {
        "type": "Agent",
        "limit": {
          "timeout": "PT1H",
          "count": 10
        },
        "inputs": {
          "parameters": {
            "deploymentId": "@appsetting('openAI_deploymentId')",
            "agentModelType": "AzureOpenAI",
            "messages": [
              {
                "role": "System",
                "content": "###system-prompt###"
              },
              {
                "role": "User",
                "content": "@{triggerBody()?['question']}"
              }
            ],
            "agentModelSettings": {
              "deploymentModelProperties": {
                "name": "@appsetting('openAI_modelName')"
              },
              "agentChatCompletionSettings": {
                "maxTokens": 3000,
                "frequencyPenalty": 0.1,
                "presencePenalty": 0.1,
                "temperature": 0.1,
                "topP": 0.1
              }
            }
          },
          "modelConfigurations": {
            "model1": {
              "referenceName": "agentConnection1"
            }
          }
        },
        "tools": {
          "get_weather": {
            "description": "Gets the current weather for a location.",
            "agentParameterSchema": {
              "type": "object",
              "properties": {
                "Get_current_weather-location": {
                  "type": "string",
                  "description": "The location to get the weather for",
                  "required": true
                }
              }
            },
            "actions": {
              "Get_current_weather": {
                "type": "ApiConnection",
                "inputs": {
                  "host": {
                    "connection": {
                      "referenceName": "msnweather"
                    }
                  },
                  "method": "get",
                  "path": "/current/@{encodeURIComponent(agentparameters('Get_current_weather-location'))}",
                  "queries": {
                    "units": "I"
                  }
                }
              },
              "Compose_action": {
                "type": "Compose",
                "inputs": "@outputs('Get_current_weather')",
                "runAfter": {
                  "Get_current_weather": ["Succeeded"]
                }
              }
            }
          },
          "notify": {
            "description": "Send a notification with a summary message.",
            "agentParameterSchema": {
              "type": "object",
              "properties": {
                "send_note-body": {
                  "type": "string",
                  "description": "The note to send",
                  "required": true
                }
              }
            },
            "actions": {
              "send_note": {
                "type": "Http",
                "inputs": {
                  "uri": "@parameters('notify-url')",
                  "method": "POST",
                  "body": {
                    "report": "@agentparameters('send_note-body')"
                  }
                },
                "runtimeConfiguration": {
                  "contentTransfer": {
                    "transferMode": "Chunked"
                  }
                }
              }
            }
          }
        }
      },
      "Response": {
        "type": "Response",
        "kind": "http",
        "inputs": {
          "statusCode": 200,
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "answer": "@{outputs('Agent_Loop')?['LastAssistantMessage']}",
            "runId": "@workflow()['run']['name']"
          }
        },
        "runAfter": {
          "Agent_Loop": ["Succeeded"]
        }
      }
    },
    "contentVersion": "1.0.0.0",
    "outputs": {},
    "triggers": {
      "When_a_HTTP_request_is_received": {
        "type": "Request",
        "kind": "Http",
        "inputs": {
          "schema": {
            "type": "object",
            "properties": {
              "question": {
                "type": "string",
                "description": "The user's question for the agent"
              }
            },
            "required": ["question"]
          }
        }
      }
    }
  },
  "kind": "Stateful"
}
